# Google AI Studio → https://aistudio.google.com/apikey
#
# Server-only — never use NEXT_PUBLIC_ (that would leak the key to every browser).
#
# Every person who uses your deployed site shares this one key: their browser calls YOUR
# /api/video/* and /api/gemini routes; Next.js reads this env on the server and calls Google.
# Add GOOGLE_GENERATIVE_AI_API_KEY (and optional vars below) in your host’s dashboard
# (e.g. Vercel → Project → Settings → Environment Variables) for Production / Preview —
# not only in .env.local on your laptop.
#
# If generations fail in production: confirm the key is set for that environment. If you use
# Google Cloud “Application restrictions”, HTTP referrer rules are for browser keys; server-side
# Node requests may be blocked — prefer an unrestricted AI Studio key or appropriate API
# restrictions for server use.
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-1.5-flash
# Veo (AI video) — see https://ai.google.dev/gemini-api/docs/video and pricing:
# https://ai.google.dev/gemini-api/docs/pricing#veo-3.1
#
# Default in code is the Fast preview model (lower $/s than Standard full-quality).
# VEO_MODEL=veo-3.1-fast-generate-preview
#
# Optional cost / quality knobs (passed to the API when set):
# VEO_GENERATE_AUDIO=false          # Often cheaper without native audio; clips are silent.
# VEO_VIDEO_DURATION_SECONDS=5      # Shorter clips usually cost less (per-second billing).
# VEO_VIDEO_RESOLUTION=720p         # Native Veo sizes: 720p (default tier), 1080p, 4k (see docs for duration limits).
# VEO_VIDEO_RESOLUTION=480p         # Not supported by Veo — app maps to 720p + OPTIMIZED compression (smaller file).
# VEO_VIDEO_COMPRESSION=optimized   # Smaller MP4. Use "lossless" for larger files / max quality.

# Nomi accounts & posts — Upstash Redis REST (production / shared persistence).
# Without these, the app uses a local JSON file in development only, or ephemeral memory on
# serverless hosts — not true cross-device continuity.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# Optional persistent file fallback (when Redis is not set):
# - Point this to a path on mounted persistent storage in your host/container.
# - Relative paths resolve from the project root.
# - In development, this is optional because Nomi already uses ./data/nomi-cloud.json.
# NOMI_DB_FILE_PATH=/var/lib/nomi/nomi-db.json
#
# Temporary escape hatch only (NOT recommended for real deployments):
# If true, allows production to run with in-memory ephemeral DB when no Redis/file path is set.
# NOMI_ALLOW_EPHEMERAL_DB=false
