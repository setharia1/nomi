# Google AI Studio → https://aistudio.google.com/apikey
# Server-only; never use NEXT_PUBLIC_ for this.
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-1.5-flash
# Veo (AI video) — see https://ai.google.dev/gemini-api/docs/video and pricing:
# https://ai.google.dev/gemini-api/docs/pricing#veo-3.1
#
# Default in code is the Fast preview model (lower $/s than Standard full-quality).
# VEO_MODEL=veo-3.1-fast-generate-preview
#
# Optional cost / quality knobs (passed to the API when set):
# VEO_GENERATE_AUDIO=false          # Often cheaper without native audio; clips are silent.
# VEO_VIDEO_DURATION_SECONDS=5      # Shorter clips usually cost less (per-second billing).
# VEO_VIDEO_RESOLUTION=720p         # Native Veo sizes: 720p (default tier), 1080p, 4k (see docs for duration limits).
# VEO_VIDEO_RESOLUTION=480p         # Not supported by Veo — app maps to 720p + OPTIMIZED compression (smaller file).
# VEO_VIDEO_COMPRESSION=optimized   # Smaller MP4. Use "lossless" for larger files / max quality.
